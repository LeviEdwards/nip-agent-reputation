  "handler_event": {
    "description": "NIP-89 kind 31990 service handler declaration",
    "event": {
      "kind": 31990,
      "pubkey": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "created_at": 1775064222,
      "tags": [
